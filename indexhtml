      <ul>
        <li><strong>实例属性</strong>：属于每个对象，各自独立</li>
        <li><strong>类属性</strong>：属于类本身，所有对象共享</li>
        <li>适合用类属性的场景：默认配置、共享常量</li>
      </ul>
      <div class="code-block">
<span class="keyword">class</span> <span class="func">Car</span>:
    wheel = <span class="number">4</span>       <span class="comment"># 类属性</span>
    tax_rate = <span class="number">0.1</span>  <span class="comment"># 类属性</span>

    <span class="keyword">def</span> <span class="func">__init__</span>(self, brand):
        self.brand = brand  <span class="comment"># 实例属性</span>
      </div>
    </div>
    <div class="card">
      <h3><span class="icon">&#x1F333;</span> 继承 <span class="interview-badge">&#x1F525; 面试高频</span></h3>
