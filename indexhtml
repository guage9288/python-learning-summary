      </ul>
      <div class="code-block">
<span class="keyword">class</span> <span class="func">Car</span>:
    <span class="keyword">def</span> <span class="func">__init__</span>(self, brand, price):
        self.brand = brand
        self.price = price

c1 = <span class="func">Car</span>(<span class="string">"BMW"</span>, <span class="number">500000</span>)
