    <div class="map-connector">&#x25BC;</div>
    <div class="map-row">
      <div class="map-node green">if / elif / else</div>
      <div class="map-node green">match...case</div>
      <div class="map-node green">for / while 循环</div>
      <div class="map-node green">break / continue</div>
    </div>
    <div class="map-connector">&#x25BC;</div>
    <div class="map-row">
      <div class="map-node orange">列表 list</div>
      <div class="map-node orange">字符串 str</div>
      <div class="map-node orange">元组 tuple</div>
      <div class="map-node orange">集合 set</div>
