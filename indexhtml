    <span class="keyword">def</span> <span class="func">speak</span>(self):
        <span class="keyword">pass</span>

<span class="keyword">class</span> <span class="func">Dog</span>(Animal):
    <span class="keyword">def</span> <span class="func">speak</span>(self):
