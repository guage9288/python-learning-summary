<div class="container">

<!-- ===================== 知识体系总览 ===================== -->
<div class="section">
  <div class="section-header">
    <div class="badge">&#x1F4CA;</div>
    <h2>知识体系总览</h2>
  </div>
  <div class="knowledge-map">
    <div class="map-row">
      <div class="map-node blue">字面量与变量</div>
