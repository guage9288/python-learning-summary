<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Python 学习总结</title>
<style>
  :root {
    --primary: #306998;
    --primary-light: #4B8BBE;
    --accent: #FFD43B;
    --accent-dark: #C9A227;
    --bg: #f4f6f9;
    --card-bg: #ffffff;
    --text: #2c3e50;
    --text-light: #6c757d;
    --code-bg: #1e1e2e;
    --code-text: #cdd6f4;
    --border: #e0e4e8;
    --shadow: 0 4px 20px rgba(0,0,0,0.08);
    --radius: 12px;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
    background: var(--bg);
    color: var(--text);
    line-height: 1.7;
  }

  /* Header */
  。hero {
    background: linear-gradient(135deg, #306998 0%, #4B8BBE 50%, #306998 100%);
    color: #fff;
    padding: 60px 20px 50px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .hero::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0; right: 0;
    height: 40px;
    background: var(--bg);
    clip-path: ellipse(55% 100% at 50% 100%);
  }
  .hero .logo {
    font-size: 64px;
    margin-bottom: 10px;
    display: inline-block;
    animation: float 3s ease-in-out infinite;
  }
  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-8px); }
  }
  .hero h1 { font-size: 2.4em; font-weight: 700; margin-bottom: 8px; }
  .hero p { font-size: 1.15em; opacity: 0.9; }

  /* Roadmap */
  .roadmap {
    max-width: 900px;
    margin: -10px auto 0;
    padding: 0 20px;
    position: relative;
    z-index: 1;
  }
  .roadmap-bar {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
    flex-wrap: wrap;
    background: var(--card-bg);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    padding: 18px 24px;
  }
  .roadmap-item {
    display: flex;
    align-items: center;
    font-size: 0.82em;
    font-weight: 600;
    color: var(--primary);
    white-space: nowrap;
  }
  .roadmap-item .num {
    width: 28px; height: 28px;
    background: var(--primary);
    color: #fff;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 0.85em;
    margin-right: 6px;
    flex-shrink: 0;
  }
  .roadmap-arrow {
    color: var(--accent-dark);
    margin: 0 10px;
    font-size: 1.2em;
  }

  /* Main content */
  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 40px 20px 60px;
  }

  /* Section */
  .section {
    margin-bottom: 48px;
  }
  .section-header {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 20px;
    padding-bottom: 12px;
    border-bottom: 3px solid var(--primary);
  }
  .section-header .badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px; height: 44px;
    background: var(--primary);
    color: #fff;
    border-radius: 10px;
    font-size: 1.3em;
    flex-shrink: 0;
  }
  .section-header h2 {
    font-size: 1.5em;
    color: var(--primary);
  }
  .section-header .tag {
    font-size: 0.75em;
    background: var(--accent);
    color: var(--text);
    padding: 2px 10px;
    border-radius: 20px;
    font-weight: 600;
  }

  /* Cards grid */
  .cards {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 20px;
  }
  .card {
    background: var(--card-bg);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    padding: 24px;
    transition: transform 0.2s, box-shadow 0.2s;
    border-left: 4px solid var(--primary-light);
  }
  .card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 30px rgba(0,0,0,0.12);
  }
  .card h3 {
    font-size: 1.1em;
    margin-bottom: 12px;
    color: var(--primary);
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .card h3 .icon { font-size: 1.2em; }
  .card ul {
    list-style: none;
    padding: 0;
  }
  .card li {
    padding: 4px 0;
    padding-left: 18px;
    position: relative;
    font-size: 0.93em;
    color: var(--text);
  }
  .card li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 11px;
    width: 8px; height: 8px;
    background: var(--accent);
    border-radius: 50%;
  }

  /* Code block */
  .code-block {
    background: var(--code-bg);
    color: var(--code-text);
    border-radius: 8px;
    padding: 16px 20px;
    margin-top: 12px;
    font-family: "JetBrains Mono", "Fira Code", "Cascadia Code", Consolas, monospace;
    font-size: 0.85em;
    line-height: 1.6;
    overflow-x: auto;
  }
  .code-block .comment { color: #6c7086; }
  .code-block .keyword { color: #cba6f7; }
  .code-block .string { color: #a6e3a1; }
  .code-block .func { color: #89b4fa; }
  .code-block .number { color: #fab387; }

  /* Summary table */
  .summary-table {
    width: 100%;
    border-collapse: collapse;
    background: var(--card-bg);
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow);
    margin-top: 12px;
  }
  .summary-table th {
    background: var(--primary);
    color: #fff;
    padding: 12px 16px;
    text-align: left;
    font-weight: 600;
    font-size: 0.92em;
  }
  .summary-table td {
    padding: 10px 16px;
    border-bottom: 1px solid var(--border);
    font-size: 0.9em;
  }
  .summary-table tr:last-child td { border-bottom: none; }
  .summary-table tr:hover td { background: #f0f4f8; }
  .summary-table code {
    background: #e8f0fe;
    color: var(--primary);
    padding: 2px 6px;
    border-radius: 4px;
    font-size: 0.9em;
    font-family: "JetBrains Mono", Consolas, monospace;
  }

  /* Knowledge map */
  .knowledge-map {
    background: var(--card-bg);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    padding: 32px;
    margin-top: 12px;
  }
  .map-row {
    display: flex;
    align-items: stretch;
    gap: 16px;
    margin-bottom: 16px;
    flex-wrap: wrap;
  }
  .map-node {
    flex: 1;
    min-width: 140px;
    text-align: center;
    padding: 14px 10px;
    border-radius: 10px;
    font-weight: 600;
    font-size: 0.9em;
    position: relative;
  }
  .map-node.blue { background: #e8f4fd; color: #1a5276; border: 2px solid #aed6f1; }
  .map-node.green { background: #e8f8f0; color: #1a6b47; border: 2px solid #a9dfbf; }
  .map-node.orange { background: #fef5e7; color: #7d5a00; border: 2px solid #f9d976; }
  .map-node.purple { background: #f0e8fd; color: #5b2c8a; border: 2px solid #d2b4f0; }
  .map-node.red { background: #fde8ea; color: #8a1c2c; border: 2px solid #f0a6ad; }
  .map-center {
    background: var(--primary);
    color: #fff;
    font-size: 1em;
    box-shadow: 0 4px 12px rgba(48,105,152,0.3);
  }

  /* Connector arrows */
  .map-connector {
    text-align: center;
    color: var(--text-light);
    font-size: 1.4em;
    margin: 4px 0;
  }

  /* Footer */
  .footer {
    text-align: center;
    padding: 30px 20px;
    color: var(--text-light);
    font-size: 0.88em;
    border-top: 1px solid var(--border);
  }

  /* Back to top */
  .back-to-top {
    position: fixed;
    bottom: 30px;
    right: 30px;
    width: 48px;
    height: 48px;
    background: var(--primary);
    color: #fff;
    border: none;
    border-radius: 50%;
    font-size: 1.4em;
    cursor: pointer;
    box-shadow: 0 4px 16px rgba(48,105,152,0.4);
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.3s, transform 0.3s;
    z-index: 100;
  }
  .back-to-top.show {
    opacity: 1;
    transform: translateY(0);
  }
  .back-to-top:hover {
    background: #24557d;
  }

  /* Mnemonic cards */
  .mnemonic {
    background: linear-gradient(135deg, #fff9e6, #fff3cc);
    border: 2px dashed #e6a817;
    border-radius: var(--radius);
    padding: 20px 24px;
    margin-top: 16px;
    position: relative;
  }
  .mnemonic::before {
    content: '';
    position: absolute;
    top: -1px; left: 24px;
    width: 40px; height: 6px;
    background: var(--accent);
    border-radius: 0 0 4px 4px;
  }
  .mnemonic-title {
    font-size: 0.85em;
    color: #b8860b;
    font-weight: 700;
    margin-bottom: 10px;
    letter-spacing: 1px;
  }
  .mnemonic-title .icon { margin-right: 4px; }
  .mnemonic p {
    font-size: 0.92em;
    color: #5a4000;
    line-height: 1.8;
    margin: 4px 0;
  }
  .mnemonic p strong {
    color: #8b6914;
  }

  /* Interview badge */
  .interview-badge {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 0.7em;
    font-weight: 700;
    background: linear-gradient(135deg, #ff6b35, #ff3333);
    color: #fff;
    padding: 3px 10px;
    border-radius: 20px;
    margin-left: 8px;
    letter-spacing: 0.5px;
    vertical-align: middle;
    box-shadow: 0 2px 8px rgba(255,51,51,0.3);
    animation: pulse-glow 2s ease-in-out infinite;
  }
  @keyframes pulse-glow {
    0%, 100% { box-shadow: 0 2px 8px rgba(255,51,51,0.3); }
    50% { box-shadow: 0 2px 16px rgba(255,51,51,0.5); }
  }
  .card:has(.interview-badge) {
    border-left-color: #ff3333;
  }

  /* Responsive */
  @media (max-width: 640px) {
    .hero h1 { font-size: 1.6em; }
    .cards { grid-template-columns: 1fr; }
    .roadmap-bar { flex-direction: column; gap: 8px; }
    .roadmap-arrow { transform: rotate(90deg); margin: 0; }
    .map-row { flex-direction: column; }
  }
</style>
</head>
